rules_version = '2';

// HireMe — production Firestore rules (deny-by-default).
// Deploy manually: firebase deploy --only firestore:rules
//
// Projections:
// - publicCandidateProfiles: discovery + unauth single-doc preview (endorse links). Sync via Admin API.
// - publicJobs: optional public posting slice. Sync via Admin API after job create/edit.
// - Employer rich candidate view: GET /api/employer/candidate-profile/:id (server field-masking), not full users/* client reads.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function currentUserDoc() {
      return get(userPath(request.auth.uid)).data;
    }

    function currentUserRole() {
      return signedIn()
        && exists(userPath(request.auth.uid))
        && currentUserDoc().keys().hasAny(['role'])
        ? string(currentUserDoc().role)
        : '';
    }

    function currentUserCompanyId() {
      return signedIn()
        && exists(userPath(request.auth.uid))
        && currentUserDoc().keys().hasAny(['companyId'])
        ? string(currentUserDoc().companyId)
        : '';
    }

    function isAdmin() {
      return signedIn() && currentUserRole() == 'ADMIN';
    }

    function isEmployerOrRecruiter() {
      return signedIn()
        && (currentUserRole() == 'EMPLOYER'
            || currentUserRole() == 'RECRUITER'
            || currentUserRole() == 'ADMIN');
    }

    function belongsToCompany(companyId) {
      return signedIn()
        && companyId != null
        && companyId != ''
        && exists(userPath(request.auth.uid))
        && currentUserDoc().keys().hasAny(['companyId'])
        && string(currentUserDoc().companyId) == companyId;
    }

    function isCompanyOwner(companyId) {
      return belongsToCompany(companyId)
        && exists(userPath(request.auth.uid))
        && currentUserDoc().keys().hasAny(['isCompanyOwner'])
        && currentUserDoc().isCompanyOwner == true;
    }

    function jobData(jobId) {
      return get(/databases/$(database)/documents/jobs/$(jobId)).data;
    }

    function jobExists(jobId) {
      return exists(/databases/$(database)/documents/jobs/$(jobId));
    }

    function canAccessJob(jobId) {
      return signedIn()
        && jobExists(jobId)
        && (
          jobData(jobId).employerId == request.auth.uid
          || (
            jobData(jobId).keys().hasAny(['companyId'])
            && jobData(jobId).companyId != null
            && string(jobData(jobId).companyId) != ''
            && belongsToCompany(string(jobData(jobId).companyId))
          )
        );
    }

    function jobIsPublicCandidateReadable() {
      return (resource.data.keys().hasAny(['status']) && resource.data.status == 'ACTIVE')
        || (resource.data.keys().hasAny(['visibility']) && resource.data.visibility == 'PUBLIC');
    }

    function threadDoc(threadId) {
      return get(/databases/$(database)/documents/messageThreads/$(threadId)).data;
    }

    function threadExists(threadId) {
      return exists(/databases/$(database)/documents/messageThreads/$(threadId));
    }

    function isThreadParticipant(threadId) {
      return signedIn()
        && threadExists(threadId)
        && threadDoc(threadId).keys().hasAny(['participantIds'])
        && threadDoc(threadId).participantIds.hasAny([request.auth.uid]);
    }

    function isThreadCompanyMember(threadId) {
      return signedIn()
        && threadExists(threadId)
        && threadDoc(threadId).keys().hasAny(['companyId'])
        && threadDoc(threadId).companyId != null
        && string(threadDoc(threadId).companyId) != ''
        && belongsToCompany(string(threadDoc(threadId).companyId));
    }

    function canReadThread(threadId) {
      return signedIn()
        && threadExists(threadId)
        && (
          isThreadParticipant(threadId)
          || isThreadCompanyMember(threadId)
        );
    }

    function threadParticipantIdsUnchanged() {
      return request.resource.data.participantIds == resource.data.participantIds;
    }

    function threadImmutableCompanyJobCandidateUnchanged() {
      return (!resource.data.keys().hasAny(['companyId']) && !request.resource.data.keys().hasAny(['companyId']))
        || request.resource.data.companyId == resource.data.companyId;
    }

    function threadJobCandidateEmployerRecruiterUnchanged() {
      return (!resource.data.keys().hasAny(['jobId']) || request.resource.data.jobId == resource.data.jobId)
        && (!resource.data.keys().hasAny(['candidateId']) || request.resource.data.candidateId == resource.data.candidateId)
        && (!resource.data.keys().hasAny(['employerId']) || request.resource.data.employerId == resource.data.employerId)
        && (!resource.data.keys().hasAny(['recruiterId']) || request.resource.data.recruiterId == resource.data.recruiterId)
        && (!resource.data.keys().hasAny(['createdBy']) || request.resource.data.createdBy == resource.data.createdBy)
        && (!resource.data.keys().hasAny(['createdAt']) || request.resource.data.createdAt == resource.data.createdAt);
    }

    function threadAllowedParticipantUpdateKeys() {
      return resource.data.diff(request.resource.data).affectedKeys()
        .hasOnly([
          'acceptedBy',
          'archivedBy',
          'mutedBy',
          'updatedAt',
          'lastMessageAt',
          'lastMessagePreview',
          'lastMessageSenderId',
          'jobId',
          'jobContext'
        ]);
    }

    // ---------------------------------------------------------------------------
    // users — no broad employer reads of JOB_SEEKER; use publicCandidateProfiles + employer API.
    // JOB_SEEKER may read employer/recruiter user docs for messaging / company UX.
    // ---------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if signedIn() && (
        request.auth.uid == userId
        || isAdmin()
        || (
          isEmployerOrRecruiter()
          && resource.data.keys().hasAny(['companyId'])
          && string(resource.data.companyId) != ''
          && string(resource.data.companyId) == currentUserCompanyId()
          && resource.data.keys().hasAny(['role'])
          && (resource.data.role == 'EMPLOYER'
              || resource.data.role == 'RECRUITER'
              || resource.data.role == 'ADMIN')
        )
        || (
          currentUserRole() == 'JOB_SEEKER'
          && resource.data.keys().hasAny(['role'])
          && (resource.data.role == 'EMPLOYER' || resource.data.role == 'RECRUITER')
        )
      );

      allow create: if signedIn() && request.auth.uid == userId;

      allow update: if signedIn() && request.auth.uid == userId;

      allow delete: if signedIn() && (
        request.auth.uid == userId
        || (
          resource.data.keys().hasAny(['role', 'companyId'])
          && resource.data.role == 'RECRUITER'
          && isCompanyOwner(string(resource.data.companyId))
        )
      );
    }

    // ---------------------------------------------------------------------------
    // publicCandidateProfiles — search-safe / endorse preview (synced server-side).
    // ---------------------------------------------------------------------------
    match /publicCandidateProfiles/{candidateId} {
      allow get: if true;
      allow list: if signedIn() && (isEmployerOrRecruiter() || isAdmin());
      allow create, update, delete: if false;
    }

    // ---------------------------------------------------------------------------
    // publicJobs — public posting slice (optional; synced server-side).
    // ---------------------------------------------------------------------------
    match /publicJobs/{jobId} {
      function publicJobReadable() {
        return (resource.data.keys().hasAny(['status']) && resource.data.status == 'ACTIVE')
          || (resource.data.keys().hasAny(['visibility']) && resource.data.visibility == 'PUBLIC');
      }
      allow get: if publicJobReadable();
      allow list: if signedIn();
      allow create, update, delete: if false;
    }

    // ---------------------------------------------------------------------------
    // Token / verification — Admin SDK only
    // ---------------------------------------------------------------------------
    match /emailVerificationTokens/{tokenId} {
      allow read, write: if false;
    }

    match /verificationCodes/{codeId} {
      allow read, write: if false;
    }

    match /verifyCodeAttempts/{id} {
      allow read, write: if false;
    }

    match /oauthStates/{stateId} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------------------------
    // companies
    // ---------------------------------------------------------------------------
    match /companies/{companyId} {
      allow read: if signedIn() && (
        (resource.data.keys().hasAny(['publicProfile']) && resource.data.publicProfile == true)
        || belongsToCompany(companyId)
      );

      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid;

      allow update, delete: if signedIn()
        && resource.data.createdBy == request.auth.uid;
    }

    // ---------------------------------------------------------------------------
    // companyInvitations
    // ---------------------------------------------------------------------------
    match /companyInvitations/{invitationId} {
      allow read: if signedIn()
        && resource.data.keys().hasAny(['companyId', 'invitedEmail'])
        && (
          isCompanyOwner(string(resource.data.companyId))
          || (
            request.auth.token.email != null
            && string(request.auth.token.email).lower() == string(resource.data.invitedEmail).lower()
          )
        );

      allow create: if signedIn()
        && request.resource.data.keys().hasAny(['companyId'])
        && isCompanyOwner(string(request.resource.data.companyId));

      allow update: if signedIn()
        && resource.data.keys().hasAny(['companyId', 'invitedEmail'])
        && (
          isCompanyOwner(string(resource.data.companyId))
          || (
            request.auth.token.email != null
            && string(request.auth.token.email).lower() == string(resource.data.invitedEmail).lower()
          )
        );

      allow delete: if signedIn()
        && resource.data.keys().hasAny(['companyId'])
        && isCompanyOwner(string(resource.data.companyId));
    }

    // ---------------------------------------------------------------------------
    // jobs — authenticated read for ACTIVE/PUBLIC (not world-readable). Internal fields still present; prefer publicJobs for public pages when migrated.
    // ---------------------------------------------------------------------------
    match /jobs/{jobId} {
      allow read: if signedIn() && (
        isAdmin()
        || canAccessJob(jobId)
        || (
          jobIsPublicCandidateReadable()
          && (currentUserRole() == 'JOB_SEEKER' || isEmployerOrRecruiter())
        )
      );

      allow create: if signedIn()
        && isEmployerOrRecruiter()
        && request.resource.data.employerId == request.auth.uid
        && (
          !request.resource.data.keys().hasAny(['companyId'])
          || request.resource.data.companyId == null
          || string(request.resource.data.companyId) == ''
          || string(request.resource.data.companyId) == currentUserCompanyId()
        );

      allow update, delete: if signedIn() && (
        resource.data.employerId == request.auth.uid
        || (
          resource.data.keys().hasAny(['companyId'])
          && resource.data.companyId != null
          && belongsToCompany(string(resource.data.companyId))
        )
      );
    }

    // ---------------------------------------------------------------------------
    // Messaging
    // ---------------------------------------------------------------------------
    match /messageThreads/{threadId} {
      allow read: if signedIn() && (
        (resource.data.keys().hasAny(['participantIds']) && resource.data.participantIds.hasAny([request.auth.uid]))
        || (
          resource.data.keys().hasAny(['companyId'])
          && resource.data.companyId != null
          && belongsToCompany(string(resource.data.companyId))
        )
      );

      allow create: if signedIn()
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() >= 2
        && request.resource.data.participantIds.hasAny([request.auth.uid])
        && (
          !request.resource.data.keys().hasAny(['companyId'])
          || request.resource.data.companyId == null
          || string(request.resource.data.companyId) == ''
          || belongsToCompany(string(request.resource.data.companyId))
        );

      allow update: if signedIn()
        && (
          (resource.data.keys().hasAny(['participantIds']) && resource.data.participantIds.hasAny([request.auth.uid]))
          || (
            resource.data.keys().hasAny(['companyId'])
            && resource.data.companyId != null
            && belongsToCompany(string(resource.data.companyId))
          )
        )
        && threadParticipantIdsUnchanged()
        && threadImmutableCompanyJobCandidateUnchanged()
        && threadJobCandidateEmployerRecruiterUnchanged()
        && threadAllowedParticipantUpdateKeys();

      allow delete: if false;
    }

    match /messages/{messageId} {
      allow read: if signedIn()
        && resource.data.keys().hasAny(['threadId'])
        && canReadThread(string(resource.data.threadId));

      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.keys().hasAny(['threadId'])
        && canReadThread(string(request.resource.data.threadId));

      allow update: if signedIn()
        && resource.data.keys().hasAny(['threadId'])
        && canReadThread(string(resource.data.threadId))
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.threadId == resource.data.threadId
        && resource.data.diff(request.resource.data).affectedKeys().hasOnly(['read', 'updatedAt']);

      allow delete: if false;
    }

    // ---------------------------------------------------------------------------
    // savedCandidates
    // ---------------------------------------------------------------------------
    match /savedCandidates/{saveId} {
      allow read, delete: if signedIn()
        && resource.data.employerId == request.auth.uid;

      allow create: if signedIn()
        && request.resource.data.employerId == request.auth.uid;

      allow update: if false;
    }

    // ---------------------------------------------------------------------------
    // profileViews
    // ---------------------------------------------------------------------------
    match /profileViews/{viewId} {
      allow read: if signedIn() && (
        resource.data.viewerId == request.auth.uid
        || resource.data.candidateId == request.auth.uid
      );

      allow create: if signedIn()
        && request.resource.data.viewerId == request.auth.uid;

      allow update, delete: if false;
    }

    // ---------------------------------------------------------------------------
    // companyRatings — authenticated read (reduces scraping vs world-readable).
    // ---------------------------------------------------------------------------
    match /companyRatings/{ratingId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow update, delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ---------------------------------------------------------------------------
    // endorsements — endorserUserId required on create; no self-endorsement (userId is candidate).
    // ---------------------------------------------------------------------------
    match /endorsements/{endorsementId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.keys().hasAny(['endorserUserId', 'userId'])
        && request.resource.data.endorserUserId == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.userId != request.auth.uid;

      allow update, delete: if signedIn() && (
        isAdmin()
        || (
          resource.data.keys().hasAny(['endorserUserId'])
          && resource.data.endorserUserId == request.auth.uid
        )
        || (
          !resource.data.keys().hasAny(['endorserUserId'])
          && resource.data.keys().hasAny(['userId'])
          && resource.data.userId == request.auth.uid
        )
      );
    }

    // ---------------------------------------------------------------------------
    // jobMatches
    // ---------------------------------------------------------------------------
    match /jobMatches/{matchId} {
      allow read: if signedIn()
        && resource.data.keys().hasAny(['jobId'])
        && canAccessJob(string(resource.data.jobId));

      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // candidatePipelineEntries
    // ---------------------------------------------------------------------------
    match /candidatePipelineEntries/{entryId} {
      allow read: if signedIn() && (
        (resource.data.keys().hasAny(['jobId']) && canAccessJob(string(resource.data.jobId)))
        || (
          resource.data.keys().hasAny(['candidateId'])
          && resource.data.candidateId == request.auth.uid
        )
      );

      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // recruiterNotes
    // ---------------------------------------------------------------------------
    match /recruiterNotes/{noteId} {
      allow read: if signedIn()
        && resource.data.keys().hasAny(['jobId'])
        && canAccessJob(string(resource.data.jobId));

      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // outreachSequences
    // ---------------------------------------------------------------------------
    match /outreachSequences/{seqId} {
      allow read: if signedIn() && (
        (resource.data.keys().hasAny(['candidateId']) && resource.data.candidateId == request.auth.uid)
        || (
          resource.data.keys().hasAny(['jobId'])
          && canAccessJob(string(resource.data.jobId))
        )
      );

      allow create: if signedIn() && (
        (
          request.resource.data.keys().hasAny(['jobId'])
          && canAccessJob(string(request.resource.data.jobId))
        )
        || (
          request.resource.data.keys().hasAll(['jobId', 'candidateId'])
          && request.resource.data.candidateId == request.auth.uid
        )
      );

      allow update: if signedIn() && (
        (
          resource.data.keys().hasAny(['candidateId'])
          && resource.data.candidateId == request.auth.uid
        )
        || (
          resource.data.keys().hasAny(['jobId'])
          && canAccessJob(string(resource.data.jobId))
        )
      );

      allow delete: if false;
    }

    // ---------------------------------------------------------------------------
    // Sensitive hiring — REST + Admin SDK only
    // ---------------------------------------------------------------------------
    match /candidateOffers/{id} {
      allow read, write: if false;
    }

    match /candidateInternalComments/{id} {
      allow read, write: if false;
    }

    match /candidateReviewAssignments/{id} {
      allow read, write: if false;
    }

    match /candidateDebriefs/{id} {
      allow read, write: if false;
    }

    match /interviewFeedback/{id} {
      allow read, write: if false;
    }

    match /interviewEvents/{id} {
      allow read, write: if false;
    }

    match /calendarIntegrations/{id} {
      allow read, write: if false;
    }

    match /interviewPlans/{id} {
      allow read, write: if false;
    }

    match /interviewPlanRounds/{id} {
      allow read, write: if false;
    }

    match /scorecardTemplates/{id} {
      allow read, write: if false;
    }

    match /talentPools/{id} {
      allow read, write: if false;
    }

    match /talentPoolMembers/{id} {
      allow read, write: if false;
    }

    match /candidateEvaluations/{id} {
      allow read, write: if false;
    }

    match /messageTemplates/{id} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------------------------
    // Deny everything else
    // ---------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
