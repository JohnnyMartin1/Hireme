# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hireme?schema=public"

# Firebase Client (Next.js Public)
NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_api_key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
NEXT_PUBLIC_FIREBASE_APP_ID="your_app_id"

# Firebase Admin (Server-side)
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"

# AWS S3 (Optional - for file uploads)
S3_REGION="us-east-1"
S3_BUCKET="your-bucket-name"
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"

# Email Configuration (Choose one)
# Option 1: Resend (Recommended for production)
RESEND_API_KEY="your_resend_api_key_here"
EMAIL_FROM="noreply@yourdomain.com"

# Option 2: Gmail SMTP
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="your_gmail_app_password"

# Option 3: Generic SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_password"

# Option 4: Development (Mailpit/Mailhog)
EMAIL_HOST="localhost"
EMAIL_PORT="1025"
EMAIL_USER=""
EMAIL_PASS=""

# Application URLs (public — used in links in emails and some fallbacks)
# NEXT_PUBLIC_APP_URL: canonical site URL for production (e.g. https://hireme.example.com). If unset, many routes fall back to VERCEL_URL or localhost.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXTAUTH_URL: legacy name still used by lib/notifications.ts and some mail helpers; set to same canonical URL as NEXT_PUBLIC_APP_URL in production.
NEXTAUTH_URL="http://localhost:3000"

# Admin (secret / config — server only except NEXT_PUBLIC_*)
# ADMIN_EMAILS: comma-separated Firebase Auth emails allowed for admin APIs and legacy admin inbox routing.
# ADMIN_EMAIL: single email if you prefer not to use ADMIN_EMAILS.
# NEXT_PUBLIC_ADMIN_EMAILS: optional comma list mirrored for client-side /admin UI gating (same addresses as server). If unset, a built-in fallback is used for backwards compatibility.
ADMIN_EMAILS=""
ADMIN_EMAIL=""
NEXT_PUBLIC_ADMIN_EMAILS=""

# CRON_SECRET (secret): Bearer value for scheduled HTTP routes (e.g. profile-reminders). Required if those endpoints are reachable.
CRON_SECRET=""

# OpenAI (secret — required for AI job parsing / matching when those features are used)
OPENAI_API_KEY=""
OPENAI_MODEL=""
OPENAI_EMBEDDING_MODEL=""
OPENAI_TIMEOUT_MS=""

# Node Environment
NODE_ENV="development"

# Google Calendar OAuth
GOOGLE_CLIENT_ID="your_google_oauth_client_id"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google-calendar/callback"

# Microsoft Calendar OAuth
MICROSOFT_CLIENT_ID="your_microsoft_app_client_id"
MICROSOFT_CLIENT_SECRET="your_microsoft_app_client_secret"
MICROSOFT_TENANT_ID="common"
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/integrations/microsoft-calendar/callback"

# Encrypts Google/Microsoft provider tokens at rest in Firestore.
# REQUIRED on Vercel (VERCEL=1) or NODE_ENV=production when persisting OAuth tokens; connect/callback will fail otherwise.
# After enabling encryption in prod, users with old plaintext tokens should disconnect and reconnect calendar once.
CALENDAR_TOKEN_ENCRYPTION_KEY="replace_with_a_long_random_secret"
